# Copy to .env.local and fill in your Anthropic key.
# .env.local is gitignored; never commit your real key.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model.
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Upstash Redis — required. Provisioned via Vercel Marketplace → Upstash → Redis.
# Vercel auto-populates these on the deployment; copy the same values here for local dev
# (or create a separate dev DB). Without these the app cannot read/write state.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
